# =============================================================================
# Obsidian Intelligence - configuration
#
# All settings are optional EXCEPT VAULT_PATH (or VAULT_SOURCE=couchdb).
# Copy this file to .env and edit. Or set the variables in your shell.
# =============================================================================

# === Required: vault source ==================================================

# Path to your Obsidian vault (filesystem source - the default)
VAULT_PATH=/path/to/your/vault

# Database location (default: <vault>/.vault-intelligence.db)
# VAULT_INTEL_DB=/custom/path/vault-intelligence.db

# === Optional: CouchDB source (Obsidian LiveSync) ============================

# Set VAULT_SOURCE=couchdb to use CouchDB instead of the filesystem.
# VAULT_SOURCE=couchdb
# COUCHDB_HOST=localhost
# COUCHDB_PORT=5984
# COUCHDB_DATABASE=obsidian
# COUCHDB_USER=admin
# COUCHDB_PASSWORD=

# === Optional: LLM provider (catalysts + enrichment) =========================
#
# Three modes:
#   1. AUTO (default): uses OpenAI if LLM_API_KEY is set, otherwise disabled.
#   2. OPENAI: any OpenAI-compatible API (OpenAI, Mistral, Together, Groq,
#      OpenRouter, LiteLLM, vLLM, LM Studio's OpenAI server, ...).
#   3. OLLAMA: local Ollama install. No API key needed.
#   4. NONE: explicitly disable LLM features.

# LLM_PROVIDER=auto              # auto | openai | ollama | none

# --- For OpenAI / OpenAI-compatible:
# LLM_API_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# --- For Ollama (local):
# LLM_PROVIDER=ollama
# LLM_API_URL=http://localhost:11434
# LLM_MODEL=llama3.2

# === Optional: Embeddings provider (semantic + hybrid search) ================
#
# Three modes:
#   1. AUTO: uses Gemini if GEMINI_API_KEY is set, then OpenAI if LLM_API_KEY
#      is set, otherwise disabled.
#   2. Explicit: gemini | openai | ollama | none
#
# Gemini's free tier is the most generous option for cloud embeddings.
# Ollama's nomic-embed-text is the easiest local option (~270 MB, CPU OK).

# EMBEDDINGS_PROVIDER=auto       # auto | gemini | openai | ollama | none

# --- For Gemini (free tier):
# GEMINI_API_KEY=
# EMBEDDINGS_MODEL=gemini-embedding-001
# EMBEDDINGS_DIMENSIONS=768

# --- For OpenAI:
# (reuses LLM_API_KEY by default)
# EMBEDDINGS_API_KEY=sk-...
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_DIMENSIONS=1536

# --- For Ollama:
# EMBEDDINGS_PROVIDER=ollama
# EMBEDDINGS_API_URL=http://localhost:11434
# EMBEDDINGS_MODEL=nomic-embed-text

# === Optional: Engagement thresholds (days) ==================================

# ENGAGEMENT_ACTIVE_DAYS=7
# ENGAGEMENT_MODERATE_DAYS=30
# ENGAGEMENT_DORMANT_DAYS=90

# === Optional: Language ======================================================

# Default language for AI-generated content (en, de, fr, ...)
# VAULT_INTEL_LANG=en
