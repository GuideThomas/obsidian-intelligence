# === Required ===

# Path to your Obsidian vault
VAULT_PATH=/path/to/your/vault

# === Optional: Database Location ===

# SQLite database path (default: <vault>/.vault-intelligence.db)
# VAULT_INTEL_DB=/custom/path/vault-intelligence.db

# === Optional: CouchDB Source (Obsidian LiveSync) ===

# Set VAULT_SOURCE=couchdb to use CouchDB instead of filesystem
# VAULT_SOURCE=couchdb
# COUCHDB_HOST=localhost
# COUCHDB_PORT=5984
# COUCHDB_DATABASE=obsidian
# COUCHDB_USER=admin
# COUCHDB_PASSWORD=

# === Optional: LLM for Catalyst Generation ===

# Any OpenAI-compatible API (OpenAI, Anthropic via proxy, Ollama, LiteLLM, etc.)
# LLM_API_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=

# === Optional: Engagement Thresholds (days) ===

# ENGAGEMENT_ACTIVE_DAYS=7
# ENGAGEMENT_MODERATE_DAYS=30
# ENGAGEMENT_DORMANT_DAYS=90

# === Optional: Language ===

# Default language for AI-generated content (en or de)
# VAULT_INTEL_LANG=en
