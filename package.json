{
  "name": "obsidian-intelligence",
  "version": "1.1.0",
  "description": "Make your Obsidian vault a first-class knowledge source for any MCP-enabled AI assistant. Local, private, headless. Graph analysis + FTS5 + semantic search + hybrid RRF + LLM enrichment.",
  "main": "vault-intelligence.js",
  "bin": {
    "vault-intelligence": "./vault-intelligence.js"
  },
  "scripts": {
    "start": "node vault-intelligence.js",
    "index": "node vault-intelligence.js index",
    "status": "node vault-intelligence.js status",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "report": "node vault-intelligence.js report"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "obsidian",
    "vault",
    "knowledge-management",
    "mcp",
    "model-context-protocol",
    "claude-desktop",
    "claude-code",
    "cursor",
    "openwebui",
    "rag",
    "semantic-search",
    "embeddings",
    "fts5",
    "hybrid-search",
    "ollama",
    "graph-analysis",
    "second-brain",
    "pkm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GuideThomas/obsidian-intelligence.git"
  },
  "bugs": {
    "url": "https://github.com/GuideThomas/obsidian-intelligence/issues"
  },
  "homepage": "https://github.com/GuideThomas/obsidian-intelligence#readme",
  "files": [
    "vault-intelligence.js",
    "mcp-server.mjs",
    "lib/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.3.1"
  },
  "optionalDependencies": {
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Thomas Winkler <mail@thomaswinkler.art>",
  "license": "MIT"
}
